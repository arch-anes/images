{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/^docker-bake\\.hcl$/"
            ],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)(?: versioning=(?<versioning>.*?))?\\s+variable \".*?\" {\\s+default = \"(?<currentValue>[^\"]+)\""
            ]
        }
    ],
    "packageRules": [
        {
            "matchCategories": [
                "docker"
            ],
            "enabled": true
        },
        {
            "automerge": true,
            "automergeType": "pr",
            "automergeStrategy": "squash",
            "matchUpdateTypes": [
                "major",
                "minor",
                "patch",
                "pin",
                "digest"
            ],
            "matchDatasources": [
                "docker"
            ]
        }
    ]
}
